# Copy this to .env and fill in the values — never commit .env

# --- Database (Neon PostgreSQL) ---
# Get this from your Neon project dashboard
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Authentication ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store this value in Render environment variables AND in the mobile app's secure storage
API_KEY="your-256-bit-hex-secret-here"

# --- Server ---
PORT=3000
LOG_LEVEL=info

# --- Google Drive ---
# OAuth2 credentials — create a Web Application OAuth client in GCP
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
# Run `npm run auth:google` once locally to generate this
GOOGLE_REFRESH_TOKEN="your-refresh-token"
# The ID of the Drive folder to upload backups into (from the folder's URL)
GOOGLE_DRIVE_FOLDER_ID="your-drive-folder-id"
