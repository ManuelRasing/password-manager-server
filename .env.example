# Copy this to .env and fill in the values — never commit .env

# --- Database (Neon PostgreSQL) ---
# Get this from your Neon project dashboard
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Authentication ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Store this value in Render environment variables AND in the mobile app's secure storage
API_KEY="your-256-bit-hex-secret-here"

# --- Server ---
PORT=3000
LOG_LEVEL=info

# --- Google Drive ---
# Paste the entire service account JSON as a single-line string (no newlines)
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'
# The ID of the Drive folder to upload backups into (from the folder's URL)
GOOGLE_DRIVE_FOLDER_ID="your-drive-folder-id"
